# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
ENV/
env/
.conda/
.ipynb_checkpoints/

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/
*.egg

# Test and coverage
.coverage
.cache/
.pytest_cache/
htmlcov/

# Logs and local data
*.log
logs/
*.sqlite
*.db

# IDE/editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Environment and secrets
.env
.env.*
deploy/.env
*.pem
*.key

# Docker
docker-compose.override.yml
**/.dockerignore

# Benchmarks and reports
benchmarks/reports/
benchmarks/tmp/
reports/
artifacts/

# Generated receipts (keep if you want to publish; ignore by default)
**/receipts/*.json
**/receipts/*.bin

# Node/yarn (if web assets are later added)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Type checker caches
.mypy_cache/
.pyre/
.pytype/
ruff_cache/
pytestdebug.log
