# ============================================
# VPS / Tailscale
# ============================================

TS_HOSTNAME=vps-node
VPS_TS_IP=100.76.145.67
LAPTOP_TS_IP=100.83.83.86
TS_SSH_ALLOW=laptop-node

# ============================================
# SSH
# ============================================

SSH_USER=butterflyfx
SSH_KEY=~/.ssh/id_rsa
SSH_PORT=22

# ============================================
# Domain Ecosystem
# ============================================

DOMAIN_BUTTERFLYFX_US=butterflyfx.us
ROLE_BUTTERFLYFX_US="Identity dimension"

DOMAIN_BUTTERFLYFXHD=butterflyfxhd.com
ROLE_BUTTERFLYFXHD="Media dimension"

DOMAIN_DIMENSIONOS=dimensionos.net
ROLE_DIMENSIONOS="Kernel dimension"

DOMAIN_GNOPPING=gnopping.com
ROLE_GNOPPING="Game dimension"

DOMAIN_KENETICARTS=keneticarts.com
ROLE_KENETICARTS="Creative dimension"

DOMAIN_KENSGAMES=kensgames.com
ROLE_KENSGAMES="Launcher dimension"

DOMAIN_PRINCIPIA=principiapizzeria.xyz
ROLE_PRINCIPIA="Experimental dimension"

DOMAIN_TETRACUBEDB=tetracubedb.com
ROLE_TETRACUBEDB="Data geometry dimension"

DOMAIN_CONDUIT=theconduit.me
ROLE_CONDUIT="Identity portal dimension"

DOMAIN_TTLRECALL=ttlrecall.com
ROLE_TTLRECALL="Memory dimension"

DOMAIN_TWISTEDSQUARE=twistedsquaredot.com
ROLE_TWISTEDSQUARE="Topology dimension"

DOMAIN_UNWALLED=unwalledgarden.us
ROLE_UNWALLED="Social dimension"

DOMAIN_VALUESAI=valuesai.online
ROLE_VALUESAI="Alignment dimension"

# ============================================
# Models
# ============================================

DEFAULT_MODEL=deepseek-coder:1.3b
FALLBACK_MODEL=llama3.2:3b
EMBEDDING_MODEL=nomic-embed-text

OLLAMA_PORT=11434
OLLAMA_HOST=http://$VPS_TS_IP:$OLLAMA_PORT

# ============================================
# Deployment
# ============================================

DEPLOY_DIR=/home/$SSH_USER/deploy
ARTIFACT_DIR=$DEPLOY_DIR/artifacts
SERVICE_DIR=$DEPLOY_DIR/service
PROJECT_DIR=/home/$SSH_USER/projects

# ============================================
# CI/CD
# ============================================

REPO_OWNER=butterflyfx
REPO_NAME=butterflyfx-app
DEPLOY_BRANCH=main

# ============================================
# Agent
# ============================================

AGENT_LOG_DIR=/home/$SSH_USER/agent/logs
AGENT_STATE_DIR=/home/$SSH_USER/agent/state
AGENT_TOOLS_ENABLED=read,write,run,ssh,scp